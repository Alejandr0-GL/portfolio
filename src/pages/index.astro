---

import AboutMe from '../components/AboutMe.astro';
import Badge from '../components/badge.astro';
import Education from '../components/Education.astro';
import Footer from '../components/Footer.astro';
import GitHubIcon from '../components/icons/GitHubIcon.astro';
import LinkedInIcon from '../components/icons/LinkedInIcon.astro';
import MailIcon from '../components/icons/MailIcon.astro';
import Projects from '../components/Projects.astro';
import SocialMedia from '../components/SocialMedia.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio de Alejandro Guevara">
	<main>
	<section class="w-full mx-auto max-w-[1100px] px-4 sm:px-6 py-20 pb-16">
			<div class="flex flex-col md:flex-row gap-8 md:gap-x-12 items-start md:items-center">
				<div class="hidden sm:block">
					<img 
							class="rounded-full w-28 h-28 sm:w-36 sm:h-36 md:w-40 md:h-40"
        				src="/photo.jpg" 
        				alt="Avatar"
    				/>
				</div>
				<div>
					<h1 class="text-white text-3xl sm:text-4xl md:text-5xl font-bold flex flex-col sm:flex-row sm:items-center items-start gap-3 sm:gap-x-6 pb-4">
						<span>Hola! Soy Alejandro</span> <a href="http://www.linkedin.com/in/alejandroguevara10" class="hidden sm:inline-flex justify-center items-center"><Badge color="blue">Disponible para trabajar</Badge></a>
					</h1>
					<h2 class="text-base sm:text-lg md:text-xl opacity-70">
						Tecnologo en desarrollo de software y estudiante de ingenieria de software 
					</h2>
					<nav class="flex flex-wrap gap-3 sm:gap-x-4 mt-5">
						<SocialMedia href="http://www.linkedin.com/in/alejandroguevara10">
							<LinkedInIcon class="w-4 h-4 sm:w-6 sm:h-6"/>
							LinkedIn
						</SocialMedia>
						<SocialMedia href="https://github.com/Alejandr0-GL">
							<GitHubIcon class="w-4 h-4 sm:w-6 sm:h-6"/>
							GitHub
						</SocialMedia>
						<SocialMedia href="mailto:alejo.gl031@gmail.com">
							<MailIcon class="w-4 h-4 sm:w-6 sm:h-6"/>
							alejo.gl031@gmail.com
						</SocialMedia>
					</nav>
				</div>
				
			</div>
			
			
		</section>

		

		<section class="mx-auto max-w-[1100px] px-4 sm:px-6 pb-6" id="projects">
			<Projects />
		</section>

		<section class="mx-auto max-w-[1100px] px-4 sm:px-6 pb-16" id="education">
			<Education />
		</section>

		<section class="mx-auto max-w-[1100px] px-4 sm:px-6 pb-16" id="about">
			<AboutMe />
		</section>
		
		

	</main>
</Layout>
